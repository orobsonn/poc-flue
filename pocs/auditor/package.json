{
  "name": "auditor",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "flue dev --target cloudflare --env ../../.dev.vars",
    "build": "flue build --target cloudflare",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "seed-baseline": "tsx scripts/seed-baseline.ts",
    "replay": "tsx scripts/replay.ts",
    "sync-r2": "tsx scripts/sync-r2.ts"
  },
  "dependencies": {
    "@flue/sdk": "^0.3.11",
    "agents": "^0.12.3",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@flue/cli": "^0.3.11",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.0",
    "wrangler": "^4.90.0"
  }
}
